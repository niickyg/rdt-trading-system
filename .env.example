# =============================================================================
# RDT TRADING SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env files with real credentials to version control!
#
# Generate secure keys with: python scripts/generate_secrets.py
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL - Production)
# =============================================================================

# PostgreSQL Connection String (REQUIRED in production)
# Format: postgresql://user:password@host:port/database
# Examples:
#   Local: postgresql://rdt:your_password@localhost:5432/rdt_trading
#   Docker: postgresql://rdt:your_password@db:5432/rdt_trading
#   Remote: postgresql://rdt:your_password@your-db-server.com:5432/rdt_trading
DATABASE_URL=postgresql://rdt:${POSTGRES_PASSWORD}@db:5432/rdt_trading

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=rdt
POSTGRES_PASSWORD=change_me_to_a_secure_password
POSTGRES_DB=rdt_trading
POSTGRES_PORT=5432

# Connection Pool Settings (optional, defaults shown)
# DB_POOL_SIZE=5           # Base pool size
# DB_POOL_MAX_OVERFLOW=10  # Max additional connections
# DB_POOL_TIMEOUT=30       # Seconds to wait for connection
# DB_POOL_RECYCLE=1800     # Recycle connections after N seconds
# DB_POOL_PRE_PING=true    # Health check before use

# SQLite fallback for local development (uncomment to use)
# DATABASE_URL=sqlite:///data/rdt_trading.db

# =============================================================================
# REQUIRED SECRETS (Must be set in production)
# =============================================================================

# Flask Secret Key - REQUIRED IN PRODUCTION
# Used for session signing and CSRF protection
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# =============================================================================
# API AUTHENTICATION SECRETS
# =============================================================================

# API Secret Key - For signing API tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=

# JWT Secret Key - For JSON Web Token signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# =============================================================================
# BROKER CREDENTIALS
# =============================================================================

# Schwab API Credentials
# Get these from: https://developer.schwab.com/
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here
SCHWAB_CALLBACK_URL=https://localhost:8080
SCHWAB_TOKEN_PATH=./schwab_token.json

# Interactive Brokers Credentials
# Get these from: https://www.interactivebrokers.com/en/trading/client-portal-api.php
IBKR_CLIENT_ID=your_client_id_here
IBKR_CLIENT_SECRET=your_client_secret_here
IBKR_GATEWAY_HOST=localhost
IBKR_GATEWAY_PORT=5000

# =============================================================================
# PAYMENT PROCESSING (Stripe)
# =============================================================================

# Stripe API Keys
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================================================
# ALERT SERVICE CREDENTIALS
# =============================================================================

# Alert Channels: Comma-separated list of enabled channels
# Options: pushover, discord, telegram, email, sms, desktop
# Example: ALERT_CHANNELS=email,discord,telegram
ALERT_CHANNELS=desktop

# Legacy Alert Method (for backward compatibility)
ALERT_METHOD=desktop

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email Provider: smtp, sendgrid, ses
EMAIL_PROVIDER=smtp
EMAIL_TO=your_email@example.com

# SMTP Configuration (for EMAIL_PROVIDER=smtp)
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com

# SendGrid Configuration (for EMAIL_PROVIDER=sendgrid)
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# AWS SES Configuration (for EMAIL_PROVIDER=ses)
# Get credentials from AWS IAM
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_SES_FROM_EMAIL=alerts@yourdomain.com

# Daily Summary Email Settings
DAILY_SUMMARY_TIME=16:30

# =============================================================================
# SMS CONFIGURATION (Twilio)
# =============================================================================

# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1234567890

# =============================================================================
# TELEGRAM ALERTS
# =============================================================================

# Create a bot: https://t.me/BotFather
# Get chat ID: Send message to bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# =============================================================================
# DISCORD ALERTS
# =============================================================================

# Create webhook: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# =============================================================================
# PUSHOVER ALERTS
# =============================================================================

# Get credentials from: https://pushover.net/
PUSHOVER_USER_KEY=your_user_key
PUSHOVER_API_TOKEN=your_api_token

# =============================================================================
# ALERT SCHEDULING (Quiet Hours)
# =============================================================================
# Configure default quiet hours when alerts will be suppressed.
# Non-critical alerts during quiet hours are queued for later delivery.
# Critical alerts always bypass quiet hours (unless override_critical=false).

# Default quiet hours start time (HH:MM in 24-hour format)
# Example: 22:00 = 10:00 PM
DEFAULT_QUIET_HOURS_START=22:00

# Default quiet hours end time (HH:MM in 24-hour format)
# Example: 07:00 = 7:00 AM
DEFAULT_QUIET_HOURS_END=07:00

# Timezone for quiet hours (IANA timezone name)
# Common options: America/New_York, America/Chicago, America/Denver, America/Los_Angeles, UTC
QUIET_HOURS_TIMEZONE=America/New_York

# File path for queued alerts storage (leave empty to disable persistence)
ALERT_QUEUE_FILE=data/alerts/queued_alerts.json

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Account Settings
ACCOUNT_SIZE=25000
MAX_RISK_PER_TRADE=0.01  # 1% risk per trade
MAX_DAILY_LOSS=0.03  # 3% max daily loss
MAX_POSITION_SIZE=0.10  # 10% max position size

# Trading Mode
PAPER_TRADING=true  # Set to false for live trading (BE CAREFUL!)
AUTO_TRADE=false  # Set to true for fully automated trading

# =============================================================================
# ADVANCED ORDERS CONFIGURATION (Bracket Orders & Trailing Stops)
# =============================================================================
# Advanced order types for enhanced risk management and profit taking.
# Bracket orders combine entry + take profit + stop loss as atomic unit.
# Trailing stops automatically adjust the stop price as the trade moves in favor.

# Enable bracket orders for all trades (entry + take profit + stop loss)
# When enabled, each trade entry will automatically place OCO exit orders
USE_BRACKET_ORDERS=false

# Enable trailing stops instead of fixed stop losses
# When enabled, stop loss orders will trail the price as it moves favorably
USE_TRAILING_STOPS=false

# Trailing stop activation percentage (profit % before trailing begins)
# The stop won't trail until the position is profitable by this percentage
# Example: 2.0 means trailing starts after position is +2% profitable
TRAILING_STOP_ACTIVATION_PCT=2.0

# Trailing stop trail percentage (how far behind the stop trails)
# The stop will trail this percentage below the highest price (for longs)
# Example: 1.5 means stop trails 1.5% below highest favorable price
TRAILING_STOP_TRAIL_PCT=1.5

# =============================================================================
# EXTENDED HOURS TRADING CONFIGURATION
# =============================================================================
# Extended hours trading allows trading during pre-market (4:00-9:30 AM ET)
# and after-hours (4:00-8:00 PM ET) sessions. Use with caution due to
# lower liquidity and wider spreads.

# Enable/disable extended hours trading
EXTENDED_HOURS_ENABLED=false

# Position size multiplier for extended hours (0.0-1.0)
# Reduces position sizes due to lower liquidity
# 0.5 = 50% of regular position size
EXTENDED_HOURS_POSITION_SIZE_PCT=0.5

# Earliest pre-market trading time (HH:MM in Eastern Time)
# Pre-market opens at 4:00 AM ET, but most retail traders start at 7:00 AM
PREMARKET_START=07:00

# Latest after-hours trading time (HH:MM in Eastern Time)
# After-hours closes at 8:00 PM ET, but liquidity drops after 6:00 PM
AFTERHOURS_END=18:00

# Enable scanning during pre-market hours
PREMARKET_SCAN_ENABLED=false

# Enable scanning during after-hours
AFTERHOURS_SCAN_ENABLED=false

# Data source for extended hours quotes (auto, broker, yfinance)
EXTENDED_HOURS_DATA_SOURCE=auto

# =============================================================================
# RRS INDICATOR SETTINGS
# =============================================================================

RRS_STRONG_THRESHOLD=2.0  # RRS above this = strong RS
RRS_MODERATE_THRESHOLD=0.5
RRS_WEAK_THRESHOLD=-2.0  # RRS below this = strong RW
ATR_PERIOD=14

# =============================================================================
# SCANNER SETTINGS
# =============================================================================

SCAN_INTERVAL_SECONDS=60  # How often to scan (60 = every minute)
MIN_VOLUME=500000  # Minimum daily volume
MIN_PRICE=5.0  # Minimum stock price
MAX_PRICE=500.0  # Maximum stock price

# =============================================================================
# WEB SERVER SETTINGS
# =============================================================================

FLASK_ENV=development  # Set to 'production' in production
FLASK_DEBUG=true  # Set to 'false' in production
PORT=5000
WEBSOCKET_ASYNC_MODE=threading  # Options: threading, eventlet, gevent

# =============================================================================
# REDIS CONFIGURATION (optional, for caching)
# =============================================================================

REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# ENVIRONMENT
# =============================================================================

# Set to 'production' for production deployments
# RDT_ENV=production

# Enable SQL query logging (useful for debugging)
# DB_ECHO=true

# =============================================================================
# ADMIN USER (for init_db.py)
# =============================================================================

# Admin credentials (optional, random password generated if not set)
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@localhost
# ADMIN_PASSWORD=your_secure_password

# =============================================================================
# GPU CONFIGURATION (Machine Learning Acceleration)
# =============================================================================
# Configure GPU settings for LSTM and deep learning model training.
# Supports NVIDIA CUDA GPUs and Apple Silicon (MPS).

# GPU usage mode: auto (detect), true (force GPU), false (force CPU)
# 'auto' will use GPU if available, otherwise fall back to CPU
USE_GPU=auto

# GPU memory limit:
# - 0: No limit (use all available memory)
# - 0-1: Fraction of GPU memory to use (e.g., 0.5 = 50%)
# - >1: Memory limit in MB (e.g., 4096 = 4GB)
GPU_MEMORY_LIMIT=0

# GPU device ID to use (-1 for auto-select, 0 for first GPU, etc.)
# Only relevant when multiple GPUs are available
GPU_DEVICE_ID=-1

# Enable GPU memory growth to prevent out-of-memory errors
# Recommended: true (allows TensorFlow to allocate memory as needed)
GPU_MEMORY_GROWTH=true

# Enable mixed precision (float16) training for faster performance
# Only supported on NVIDIA GPUs with compute capability 7.0+
GPU_MIXED_PRECISION=false

# Multi-GPU training strategy (for systems with multiple GPUs)
# Options: mirrored, multi_worker, parameter_server
GPU_MULTI_GPU_STRATEGY=mirrored

# Log TensorFlow device placement for debugging
GPU_LOG_DEVICE_PLACEMENT=false

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: 'json' for structured JSON logs, 'text' for human-readable
LOG_FORMAT=text

# Log file path (optional, leave empty to disable file logging)
# Logs are rotated automatically (10MB max, 5 backups)
LOG_FILE=./logs/rdt-trading.log

# Legacy option (deprecated, use LOG_FILE instead)
LOG_TO_FILE=true

# =============================================================================
# GRAFANA LOKI (Log Aggregation)
# =============================================================================

# Loki push API URL (used by logging handlers)
# For Docker: http://loki:3100/loki/api/v1/push
# For local: http://localhost:3100/loki/api/v1/push
LOKI_URL=http://loki:3100/loki/api/v1/push

# Enable/disable Loki log shipping
LOKI_ENABLED=false

# Loki container port mapping
LOKI_PORT=3100

# =============================================================================
# DATA RETENTION CONFIGURATION
# =============================================================================
# Manages automatic archiving and cleanup of old data.
# Run manually: python scripts/run_retention.py status
# Run with Docker: docker-compose --profile retention up

# Retention Periods (in days, 0 = keep forever)
# Adjust these based on your regulatory and business requirements

# Signals: Archive after N days (default: 90 days)
RETENTION_SIGNALS_DAYS=90

# Trades: Keep forever (regulatory requirement - SEC/FINRA)
# WARNING: Do not reduce this without legal review
RETENTION_TRADES_DAYS=0

# Positions: Archive N days after close (default: 365 days)
RETENTION_POSITIONS_DAYS=365

# Daily Stats: Archive after N days (default: 730 = 2 years)
RETENTION_DAILY_STATS_DAYS=730

# Audit Logs: Keep for N days (default: 2555 = 7 years)
# Required for SOX compliance - do not reduce without legal review
RETENTION_AUDIT_LOGS_DAYS=2555

# User Sessions: Delete after N days inactive (default: 30 days)
RETENTION_SESSIONS_DAYS=30

# API Logs: Archive after N days (default: 90 days)
RETENTION_API_LOGS_DAYS=90

# ML Predictions: Archive after N days (default: 180 = 6 months)
RETENTION_ML_PREDICTIONS_DAYS=180

# Market Data Cache: Delete after N days (default: 7 days)
RETENTION_MARKET_DATA_CACHE_DAYS=7

# Order Executions: Archive after N days (default: 365 = 1 year)
RETENTION_ORDER_EXECUTIONS_DAYS=365

# =============================================================================
# Archive Settings
# =============================================================================

# Local archive storage path
RETENTION_ARCHIVE_PATH=./archives

# Archive format: json, json_gz, or parquet
RETENTION_ARCHIVE_FORMAT=json_gz

# =============================================================================
# S3 Archive Settings (optional)
# =============================================================================

# Enable S3 archiving (requires boto3 and AWS credentials)
RETENTION_ARCHIVE_TO_S3=false

# S3 bucket for archives
# RETENTION_S3_BUCKET=your-bucket-name

# S3 key prefix for archives
RETENTION_S3_PREFIX=rdt-archives

# AWS region for S3
RETENTION_S3_REGION=us-east-1

# =============================================================================
# Archive Database Settings (optional)
# =============================================================================

# Enable separate archive database
RETENTION_ARCHIVE_DB_ENABLED=false

# Archive database connection string
# RETENTION_ARCHIVE_DB_URL=postgresql://user:pass@host:5432/rdt_archive

# =============================================================================
# Cleanup Settings
# =============================================================================

# Batch size for cleanup operations (default: 1000)
RETENTION_BATCH_SIZE=1000

# Enable soft delete (mark as deleted instead of removing)
RETENTION_SOFT_DELETE=true

# Cron schedule for automatic cleanup (default: daily at 3 AM)
# Format: minute hour day month weekday
RETENTION_CLEANUP_SCHEDULE=0 3 * * *

# =============================================================================
# Safety Settings
# =============================================================================

# Default to dry-run mode (preview only, no actual changes)
RETENTION_DRY_RUN_DEFAULT=true

# Require confirmation before cleanup operations
RETENTION_REQUIRE_CONFIRMATION=true

# Minimum records threshold (don't delete if fewer records than this)
RETENTION_MIN_RECORDS_THRESHOLD=100

# =============================================================================
# Notification Settings
# =============================================================================

# Send notification on cleanup completion
RETENTION_NOTIFY_COMPLETION=true

# Send notification on cleanup errors
RETENTION_NOTIFY_ERROR=true

# Slack webhook for retention notifications (optional)
# RETENTION_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# =============================================================================
# OPTIONS TRADING CONFIGURATION
# =============================================================================
# Full options trading support: calls, puts, spreads, iron condors.
# Requires IBKR broker with options permissions enabled.

# Master switch — enable/disable options module
OPTIONS_ENABLED=false

# Trading mode: stocks (default), options (replace stock trades), both
OPTIONS_MODE=stocks

# Delta targeting for long legs (0.50-0.70 range)
OPTIONS_LONG_DELTA_MIN=0.50
OPTIONS_LONG_DELTA_MAX=0.70
OPTIONS_LONG_DELTA_TARGET=0.60

# Delta targeting for short legs in spreads (0.25-0.35 range)
OPTIONS_SHORT_LEG_DELTA_MIN=0.25
OPTIONS_SHORT_LEG_DELTA_MAX=0.35
OPTIONS_SHORT_LEG_DELTA_TARGET=0.30
OPTIONS_DELTA_TOLERANCE=0.05

# Days to expiration targeting
OPTIONS_DTE_MIN=14
OPTIONS_DTE_MAX=60
OPTIONS_DTE_TARGET=35

# Exit management
OPTIONS_PROFIT_TARGET_PCT=0.50        # Close at 50% of max profit (spreads)
OPTIONS_LONG_PROFIT_TARGET_PCT=1.00   # Close at 100% gain (long options)
OPTIONS_STOP_LOSS_PCT=0.50            # Stop at 50% premium loss
OPTIONS_TIME_STOP_DTE=14              # Close when DTE < 14
OPTIONS_DELTA_BREACH=0.80             # Close when |delta| > 0.80
OPTIONS_IV_CRUSH_THRESHOLD=0.20       # Close when IV drops > 20%
OPTIONS_ROLL_DTE=21                   # Consider roll when DTE < 21

# IV thresholds for strategy selection (IV rank 0-100)
OPTIONS_IV_RANK_LOW=30                # Below = buy premium
OPTIONS_IV_RANK_HIGH=50               # Above = sell premium
OPTIONS_IV_RANK_VERY_HIGH=80          # Above = iron condors

# Liquidity filters
OPTIONS_MIN_OI=100                    # Minimum open interest
OPTIONS_MAX_SPREAD_PCT=10.0           # Max bid-ask spread %

# Spread width limits
OPTIONS_MAX_SPREAD_WIDTH_UNDER_100=5.0   # $5 max width for stocks < $100
OPTIONS_MAX_SPREAD_WIDTH_OVER_100=10.0   # $10 max width for stocks >= $100

# Portfolio risk limits
OPTIONS_MAX_PREMIUM_RISK_PCT=0.10     # Max 10% of account at risk
OPTIONS_MAX_PORTFOLIO_DELTA=200       # Max |net portfolio delta|
OPTIONS_MAX_DAILY_THETA_PCT=0.005     # Max daily theta (0.5% of account)
OPTIONS_MAX_PER_UNDERLYING=2          # Max options positions per symbol

# Cache settings
OPTIONS_GREEKS_CACHE_TTL=60           # Greeks cache TTL (seconds)
OPTIONS_CHAIN_CACHE_TTL=300           # Chain structure cache TTL (seconds)
OPTIONS_RATE_LIMIT_MS=50              # Rate limit between IBKR requests (ms)

# Order execution
OPTIONS_SLIPPAGE_TICKS=1              # Ticks of slippage for limit pricing

# Force a specific strategy (leave empty for auto-selection)
# Options: long_call, long_put, bull_call_spread, bear_put_spread,
#          bull_put_spread, bear_call_spread, iron_condor
OPTIONS_FORCE_STRATEGY=

# Paper trading mode (Black-Scholes pricing)
OPTIONS_RISK_FREE_RATE=0.05              # Risk-free rate for BS pricing
OPTIONS_PAPER_IV_MULTIPLIER=1.1          # HV-to-IV scaling factor for synthetic IV
